#!/usr/bin/env bash
#
# Per-metric retention for our prometheus instance.
#
# Background: prometheus has a single global retention setting and no built-in
# per-metric retention (https://github.com/prometheus/prometheus/issues/1381).
# We keep environmental metrics (temperature, humidity, electricity, etc.) for
# years but only need pi system metrics (node_*, etc.) for a couple months.
# This script trims non-env series older than RETENTION_DAYS via the prometheus
# admin delete_series + clean_tombstones APIs.
#
# Failure modes the safety check guards against:
#   - ENV_REGEX accidentally rewritten in a way that no longer matches real
#     env metrics. Without the guard, we'd wipe years of environmental data.
# It does NOT guard against ENV_REGEX being too broad (i.e. not deleting enough);
# that just means the cron does less work than intended, not data loss.
#
# See: https://github.com/dasl-/pitools/issues/13

set -euo pipefail -o errtrace

PROM_URL="${PROM_URL:-http://localhost:9090}"
ENV_REGEX="${ENV_REGEX:-^(ambient_|city_|electricity_).*}"
RETENTION_DAYS="${RETENTION_DAYS:-60}"
# When true, log what would be deleted but do not call the destructive APIs.
# Default to true so a fresh install is non-destructive until an operator opts in.
DRY_RUN="${DRY_RUN:-true}"
# Floor on env-metric series count. If fewer are found, abort without deleting.
# We currently emit 11 distinct env metric names from sensors/*; 8 leaves headroom
# for one or two sensors being temporarily offline at cron time.
SAFETY_MIN_ENV_SERIES="${SAFETY_MIN_ENV_SERIES:-8}"

main(){
    trap 'fail $? $LINENO' ERR

    local cutoff_epoch
    cutoff_epoch=$(date -u -d "${RETENTION_DAYS} days ago" +%s)
    local cutoff_human
    cutoff_human=$(date -u -d "@$cutoff_epoch" -Iseconds)

    info "Retention cron starting. cutoff=${cutoff_human} dry_run=${DRY_RUN}"

    local env_series_count
    env_series_count=$(countSeries "{__name__=~\"$ENV_REGEX\"}")
    if (( env_series_count < SAFETY_MIN_ENV_SERIES )); then
        die "Sanity check failed: only $env_series_count env series matched ENV_REGEX (expected >= $SAFETY_MIN_ENV_SERIES). Refusing to delete."
    fi
    info "Sanity check passed: $env_series_count env series matched."

    local non_env_selector
    non_env_selector="{__name__=~\".+\",__name__!~\"$ENV_REGEX\"}"

    if [[ "$DRY_RUN" == "true" ]]; then
        local non_env_series_count
        non_env_series_count=$(countSeries "$non_env_selector")
        info "DRY_RUN: would delete $non_env_series_count non-env series with end<=${cutoff_human}. Set DRY_RUN=false to actually delete."
        return 0
    fi

    info "Calling delete_series..."
    curl -fsS -X POST "$PROM_URL/api/v1/admin/tsdb/delete_series" \
        --data-urlencode "match[]=$non_env_selector" \
        --data-urlencode "end=$cutoff_epoch" >/dev/null

    info "Calling clean_tombstones..."
    curl -fsS -X POST "$PROM_URL/api/v1/admin/tsdb/clean_tombstones" >/dev/null

    info "Retention cron finished. Trimmed non-env series with end<=${cutoff_human}."
}

# Count series matching the given selector via the /api/v1/series endpoint.
countSeries(){
    local selector="$1"
    curl -fsS --get "$PROM_URL/api/v1/series" \
        --data-urlencode "match[]=$selector" \
        | python3 -c 'import sys, json; print(len(json.load(sys.stdin)["data"]))'
}

fail(){
    local exit_code=$1
    local line_no=$2
    local script_name
    script_name=$(basename "${BASH_SOURCE[0]}")
    die "Error in $script_name at line number: $line_no with exit code: $exit_code"
}

info(){
    echo -e "\x1b[32m$*\x1b[0m"
}

warn(){
    echo -e "\x1b[33m$*\x1b[0m"
}

die(){
    echo
    echo -e "\x1b[31m$*\x1b[0m" >&2
    exit 1
}

main "$@"
